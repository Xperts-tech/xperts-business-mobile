{
  "expo": {
    "name": "Xperts Driver",
    "slug": "xperts-driver-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "xperts-driver",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3558"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xpertsxpress.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Xperts Xpress uses your location to assign nearby delivery orders while you are online.",
        "NSPhotoLibraryUsageDescription": "Xperts Xpress needs access to your photo library to upload delivery proof photos, receipt images, and driver documents.",
        "NSCameraUsageDescription": "Xperts Xpress needs access to your camera to capture delivery proof photos and receipt images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.xpertsxpress.driver",
      "adaptiveIcon": {
        "backgroundColor": "#1A3558",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A3558",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bb46f001-2e2e-46ed-bef7-f4d15c40c41c"
      }
    }
  }
}
